{
  "Logging": {
    "LogLevel": {
      "Default": "Trace"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MusicDb": "Data Source=music.db"
  },
  "GoogleStorageOptions": {
    "BasePath": "./music-storage",
    "PlaylistImgPrefix": "playlist-img",
    "SongPreviewsPrefix": "song-previews"
  },
  "UseSteamSandbox": true,
  "SupportedVersions": "3"
}